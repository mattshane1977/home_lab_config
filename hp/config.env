# hp/config.env — HP DL380 Configuration
HOSTNAME="hp"

# Storage - Disks for MergerFS pool
DISK1="/dev/sdb"       # 1.6TB (behind P440ar)
DISK2="/dev/sdc"       # 1.1TB (behind P440ar)
DISK3="/dev/sdd"       # 10.9TB (direct attached)
DISK4="/dev/rssda"     # 1.3TB SABRENT NVMe/SSD

MOUNT_DISK1="/mnt/disk1"
MOUNT_DISK2="/mnt/disk2"
MOUNT_DISK3="/mnt/disk3"
MOUNT_DISK4="/mnt/disk4"
MERGE_MOUNT="/mnt/storage"
STORAGE_NAME="merged-storage"

# GPU PCI IDs (update these with: lspci -nn | grep -i nvidia)
# Tesla P100
GPU_P100_ID=""    # TODO: fill in, e.g., "0000:82:00.0"
# Tesla P40
GPU_P40_ID=""     # TODO: fill in, e.g., "0000:83:00.0"

# VM Settings
TRUENAS_VMID=100
TRUENAS_RAM=8192
TRUENAS_DISK_SIZE="500G"

DOCKER_VMID=101
DOCKER_RAM=65536    # Adjust based on total HP RAM
DOCKER_CORES=16     # Adjust based on total HP cores
