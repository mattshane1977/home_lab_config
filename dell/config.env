# dell/config.env — Dell Server Configuration
HOSTNAME="dell"

# Storage - Single disk
DISK1="/dev/sdb"       # 4.4TB
MOUNT="/mnt/storage"
STORAGE_NAME="merged-storage"

# GPU PCI ID (update with: lspci -nn | grep -i nvidia)
# RTX 4060 Ti
GPU_4060TI_ID=""    # TODO: fill in, e.g., "0000:01:00.0"

# VM Settings
COMFYUI_VMID=100
COMFYUI_RAM=32768    # Adjust based on total Dell RAM
COMFYUI_CORES=8      # Adjust based on total Dell cores
